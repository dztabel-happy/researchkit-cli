    { "os": "linux", "cpu": "x64", "package": "@dztabel/researchkit-linux-x64", "version": "0.1.0", "directory": "linux-x64", "artifact": "platforms/linux-x64/bin/research-kit", "optional": true },
    { "os": "win32", "cpu": "x64", "package": "@dztabel/researchkit-win32-x64", "version": "0.1.0", "directory": "win32-x64", "artifact": "platforms/win32-x64/bin/research-kit.exe", "optional": true }
